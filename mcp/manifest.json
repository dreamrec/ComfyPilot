{
  "name": "comfypilot",
  "version": "0.7.1",
  "description": "MCP server for practical ComfyUI control, workflow planning, documentation, and image generation tooling",
  "author": "ComfyPilot",
  "license": "MIT",
  "transport": "stdio",
  "command": "uv",
  "args": ["run", "comfypilot"],
  "env": {
    "COMFY_URL": {
      "description": "ComfyUI server URL",
      "default": "http://127.0.0.1:8188"
    },
    "COMFY_API_KEY": {
      "description": "Optional API key for ComfyUI authentication",
      "default": ""
    },
    "COMFY_AUTH_METHOD": {
      "description": "Authentication method: auto, bearer, or x-api-key",
      "default": "auto"
    },
    "COMFY_TIMEOUT": {
      "description": "HTTP request timeout in seconds",
      "default": "300"
    },
    "COMFY_SNAPSHOT_LIMIT": {
      "description": "Maximum number of workflow snapshots to retain",
      "default": "50"
    },
    "COMFY_OUTPUT_DIR": {
      "description": "Default output directory for saved images",
      "default": "~/comfypilot_output"
    },
    "COMFY_TD_OUTPUT_DIR": {
      "description": "Output directory for TouchDesigner images",
      "default": "~/comfypilot_output/touchdesigner"
    },
    "COMFY_BLENDER_OUTPUT_DIR": {
      "description": "Output directory for Blender images",
      "default": "~/comfypilot_output/blender"
    }
  },
  "categories": [
    "system",
    "models",
    "workflow",
    "nodes",
    "images",
    "history",
    "monitoring",
    "snapshots",
    "memory",
    "safety",
    "builder",
    "output_routing",
    "install",
    "compatibility",
    "docs",
    "templates",
    "knowledge",
    "registry",
    "planner"
  ]
}
